<mxfile host="app.diagrams.net">
  <diagram id="positive-sum-count" name="Блок-схема">
    <mxGraphModel dx="1200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="start" value="Начало" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="334" y="30" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="inputN" value="Ввод N" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="304" y="120" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="checkN" value="N &amp;gt; 0?" style="rhombus;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="334" y="210" width="160" height="90" as="geometry" />
        </mxCell>

        <mxCell id="outputErr" value="Вывод сообщения об ошибке:&#xa;N должно быть положительным" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;strokeWidth=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="560" y="225" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="endErr" value="Конец" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="595" y="335" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="init" value="sum_pos = 0&#xa;count_pos = 0&#xa;i = 0" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="304" y="340" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="loopCond" value="i &amp;lt; N?" style="rhombus;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="334" y="455" width="160" height="90" as="geometry" />
        </mxCell>

        <mxCell id="inputAi" value="Ввод A[i]" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="304" y="590" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="checkAi" value="A[i] &amp;gt; 0?" style="rhombus;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="334" y="695" width="160" height="90" as="geometry" />
        </mxCell>

        <mxCell id="add" value="sum_pos = sum_pos + A[i]&#xa;count_pos = count_pos + 1" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="560" y="700" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="inc" value="i = i + 1" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="304" y="835" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="outputRes" value="Вывод:&#xa;sum_pos, count_pos" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="304" y="985" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="end" value="Конец" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=2;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="334" y="1095" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="start" target="inputN"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="inputN" target="checkN"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="нет" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=13;" edge="1" parent="1" source="checkN" target="outputErr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="outputErr" target="endErr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="да" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=13;" edge="1" parent="1" source="checkN" target="init"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="init" target="loopCond"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="да" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=13;" edge="1" parent="1" source="loopCond" target="inputAi"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="inputAi" target="checkAi"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="да" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=13;" edge="1" parent="1" source="checkAi" target="add"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="add" target="inc"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="675" y="865" /></Array></mxGeometry></mxCell>
        <mxCell id="e11" value="нет" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=13;" edge="1" parent="1" source="checkAi" target="inc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" value="нет" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=13;" edge="1" parent="1" source="loopCond" target="outputRes"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="150" y="500" /><mxPoint x="150" y="1020" /></Array></mxGeometry></mxCell>
        <mxCell id="e13" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="outputRes" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="inc" target="loopCond"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="414" y="930" /><mxPoint x="215" y="930" /><mxPoint x="215" y="500" /></Array></mxGeometry></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
